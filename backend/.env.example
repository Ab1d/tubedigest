# DeepSeek API Configuration
# Get your API key from: https://platform.deepseek.com

# Required: Your DeepSeek API key
DEEPSEEK_API_KEY=your-api-key-here

# Optional: Override the default model
# DEEPSEEK_MODEL=deepseek-chat

# Optional: Override the API URL (for proxy or self-hosted instances)
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Optional: Server port
# PORT=3001

# PostgreSQL Database URL
# Format: postgresql://user:password@localhost:5432/tubedigest
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tubedigest
